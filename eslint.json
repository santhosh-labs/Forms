            className=\"pl-8 pr-3 py-1.5 text-sm border border-border rounded-lg outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary w-56 bg-background text-foreground placeholder:text-muted-foreground\"\r\n                            />\r\n                        </div>\r\n                    </div>\r\n\r\n                    {/* Table header */}\r\n                    <div className=\"grid grid-cols-[2fr_1.5fr_1fr_1fr_auto] gap-4 px-6 py-3.5 bg-background text-xs font-black uppercase tracking-widest text-muted-foreground border-b border-border\">\r\n                        <span>Form</span><span>Submitted By</span><span>Date</span><span>Status</span><span>Actions</span>\r\n                    </div>\r\n\r\n                    {/* Rows */}\r\n                    {filtered.length === 0 ? (\r\n                        <div className=\"py-16 flex flex-col items-center\">\r\n                            <ClipboardCheck size={40} className=\"mb-3 text-muted\" />\r\n                            <p className=\"text-muted-foreground font-medium text-sm\">No approvals found.</p>\r\n                        </div>\r\n                    ) : (\r\n                        <div className=\"divide-y divide-border/30\">\r\n                            {filtered.map(approval => (\r\n                                <div key={approval.id} className=\"grid grid-cols-[2fr_1.5fr_1fr_1fr_auto] gap-4 px-6 py-4 items-center hover:bg-muted/60 transition-colors\">\r\n\r\n                                    {/* Form */}\r\n                                    <div className=\"flex items-center gap-3 min-w-0\">\r\n                                        <div className=\"w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center shrink-0\">\r\n                                            <FileText size={14} className=\"text-primary\" />\r\n                                        </div>\r\n                                        <span className=\"text-sm font-semibold text-foreground truncate\">{approval.formName}</span>\r\n                                    </div>\r\n\r\n                                    {/* Submitted by */}\r\n                                    <div className=\"flex items-center gap-2 min-w-0\">\r\n                                        <div className=\"w-6 h-6 bg-primary/10 rounded-full flex items-center justify-center shrink-0\">\r\n                                            <span className=\"text-xs font-bold text-primary\">{approval.submittedBy[0]?.toUpperCase()}</span>\r\n                                        </div>\r\n                                        <span className=\"text-sm text-foreground truncate\">{approval.submittedBy}</span>\r\n                                    </div>\r\n\r\n                                    {/* Date */}\r\n                                    <div className=\"flex items-center gap-1.5 text-sm text-muted-foreground\">\r\n                                        <Calendar size={12} className=\"shrink-0\" />\r\n                                        {new Date(approval.submittedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}\r\n                                    </div>\r\n\r\n                                    {/* Status */}\r\n                                    <StatusBadge status={approval.status} />\r\n\r\n                                    {/* Actions */}\r\n                                    <div className=\"flex items-center gap-1\">\r\n                                        <button\r\n                                            onClick={() => setDetailModal(approval)}\r\n                                            title=\"View details\"\r\n                                            className=\"p-1.5 text-muted-foreground hover:text-primary hover:bg-primary/10 rounded-lg transition-colors\"\r\n                                        >\r\n                                            <Eye size={14} />\r\n                                        </button>\r\n                                        {approval.status === 'Pending' && (\r\n                                            <>\r\n                                                <button\r\n                                                    onClick={() => setActionModal({ approval, action: 'approve' })}\r\n                                                    title=\"Approve\"\r\n                                                    className=\"p-1.5 text-muted-foreground hover:text-emerald-600 hover:bg-emerald-500/10 rounded-lg transition-colors\"\r\n                                                >\r\n                                                    <Check size={14} />\r\n                                                </button>\r\n                                                <button\r\n                                                    onClick={() => setActionModal({ approval, action: 'reject' })}\r\n                                                    title=\"Reject\"\r\n                                                    className=\"p-1.5 text-muted-foreground hover:text-destructive hover:bg-destructive/10 rounded-lg transition-colors\"\r\n                                                >\r\n                                                    <X size={14} />\r\n                                                </button>\r\n                                            </>\r\n                                        )}\r\n                                    </div>\r\n                                </div>\r\n                            ))}\r\n                        </div>\r\n                    )}\r\n                </div>\r\n            </div>\r\n\r\n            {/* Modals */}\r\n            {actionModal && (\r\n                <ActionModal\r\n                    approval={actionModal.approval}\r\n                    action={actionModal.action}\r\n                    onClose={() => setActionModal(null)}\r\n                    onConfirm={(note) => handleAction(\r\n                        actionModal.approval.id,\r\n                        actionModal.action === 'approve' ? 'Approved' : 'Rejected',\r\n                        note\r\n                    )}\r\n                />\r\n            )}\r\n            {detailModal && (\r\n                <DetailModal approval={detailModal} onClose={() => setDetailModal(null)} />\r\n            )}\r\n        </MainLayout>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\MyFolders.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\MyReports.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\MyTasks.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\OrgForms.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\SharedFolders.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'sharedToMeFolders' array makes the dependencies of useMemo Hook (at line 108) change on every render. To fix this, wrap the initialization of 'sharedToMeFolders' in its own useMemo() Hook.","line":100,"column":11,"nodeType":"VariableDeclarator","endLine":104,"endColumn":6}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useMemo } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport MainLayout from '../components/layout/MainLayout';\r\nimport { useFormStore } from '../store/useFormStore';\r\nimport { FolderItem } from '../types';\r\nimport {\r\n    FolderOpen, Folder, FileText, Search, Users,\r\n    LayoutGrid, List, UserCircle2,\r\n} from 'lucide-react';\r\n\r\nfunction hexToRgb(hex: string) {\r\n    const r = parseInt(hex.slice(1, 3), 16);\r\n    const g = parseInt(hex.slice(3, 5), 16);\r\n    const b = parseInt(hex.slice(5, 7), 16);\r\n    return `${r},${g},${b}`;\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Folder Detail 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nfunction SharedFolderDetail({ folder, forms, onBack }: {\r\n    folder: FolderItem;\r\n    forms: { id: string; name: string; submissions: number }[];\r\n    onBack: () => void;\r\n}) {\r\n    const navigate = useNavigate();\r\n    return (\r\n        <div>\r\n            <button onClick={onBack} className=\"flex items-center gap-2 text-sm text-teal-600 hover:text-teal-700 mb-5 font-medium\">\r\n                螕氓脡 Shared Folders\r\n            </button>\r\n            <div className=\"flex items-center gap-3 mb-2\">\r\n                <div className=\"w-10 h-10 rounded-xl flex items-center justify-center\" style={{ backgroundColor: `rgba(${hexToRgb(folder.color)},0.15)` }}>\r\n                    <FolderOpen size={22} style={{ color: folder.color }} />\r\n                </div>\r\n                <div>\r\n                    <h2 className=\"text-xl font-bold text-gray-900\">{folder.name}</h2>\r\n                    <p className=\"text-sm text-gray-400\">Shared by {folder.sharedBy}</p>\r\n                </div>\r\n            </div>\r\n            <p className=\"text-sm text-gray-400 mb-6\">{forms.length} form{forms.length !== 1 ? 's' : ''}</p>\r\n\r\n            {forms.length === 0 ? (\r\n                <div className=\"bg-white rounded-xl border border-gray-200 py-16 text-center\">\r\n                    <FileText size={40} className=\"mx-auto text-gray-200 mb-3\" />\r\n                    <p className=\"text-gray-400 text-sm\">No forms in this shared folder.</p>\r\n                </div>\r\n            ) : (\r\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4\">\r\n                    {forms.map(form => (\r\n                        <div key={form.id}\r\n                            onClick={() => navigate(`/builder/${form.id}`)}\r\n                            className=\"bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow cursor-pointer\">\r\n                            <div className=\"w-10 h-10 rounded-lg flex items-center justify-center mb-3\"\r\n                                style={{ backgroundColor: `rgba(${hexToRgb(folder.color)},0.15)` }}>\r\n                                <FileText size={18} style={{ color: folder.color }} />\r\n                            </div>\r\n                            <h3 className=\"font-semibold text-gray-900 text-sm mb-1 truncate\">{form.name}</h3>\r\n                            <p className=\"text-xs text-gray-400\">{form.submissions} submissions</p>\r\n                            <p className=\"text-xs text-blue-400 mt-1 flex items-center gap-1\"><Users size={10} /> View only</p>\r\n                        </div>\r\n                    ))}\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Demo shared folders (simulated) 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nconst DEMO_SHARED: FolderItem[] = [\r\n    {\r\n        id: 'shared-demo-1',\r\n        name: 'HR Onboarding',\r\n        color: '#8b5cf6',\r\n        createdAt: '2024-01-10',\r\n        isShared: true,\r\n        sharedWith: [],\r\n        sharedBy: 'manager@company.com',\r\n    },\r\n    {\r\n        id: 'shared-demo-2',\r\n        name: 'Marketing Campaigns',\r\n        color: '#f59e0b',\r\n        createdAt: '2024-01-15',\r\n        isShared: true,\r\n        sharedWith: [],\r\n        sharedBy: 'marketing@company.com',\r\n    },\r\n];\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Main Page 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nexport default function SharedFolders() {\r\n    const allFolders = useFormStore(state => state.folders);\r\n    const allForms = useFormStore(state => state.forms);\r\n\r\n    const [openFolder, setOpenFolder] = useState<FolderItem | null>(null);\r\n    const [search, setSearch] = useState('');\r\n    const [viewMode, setViewMode] = useState<'grid' | 'list'>('grid');\r\n\r\n    // Collect folders that were explicitly shared to someone (from our own store)\r\n    // plus the demo shared folders\r\n    const sharedToMeFolders: FolderItem[] = [\r\n        ...DEMO_SHARED,\r\n        // any folder from store that has sharedBy set (simulating received-shares)\r\n        ...allFolders.filter(f => f.sharedBy),\r\n    ];\r\n\r\n    const filtered = useMemo(() =>\r\n        sharedToMeFolders.filter(f => f.name.toLowerCase().includes(search.toLowerCase())),\r\n        [sharedToMeFolders, search]\r\n    );\r\n\r\n    const formsInFolder = useMemo(() =>\r\n        openFolder\r\n            ? allForms.filter(f => f.folder === openFolder.name && !f.isDeleted)\r\n            : [],\r\n        [allForms, openFolder]\r\n    );\r\n\r\n    if (openFolder) {\r\n        return (\r\n            <MainLayout onNewFormClick={() => { }}>\r\n                <div className=\"max-w-6xl mx-auto\">\r\n                    <SharedFolderDetail folder={openFolder} forms={formsInFolder} onBack={() => setOpenFolder(null)} />\r\n                </div>\r\n            </MainLayout>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <MainLayout onNewFormClick={() => { }}>\r\n            <div className=\"max-w-6xl mx-auto\">\r\n                {/* Header */}\r\n                <div className=\"flex items-center justify-between mb-6\">\r\n                    <h1 className=\"text-2xl font-bold text-gray-900\">Shared Folders</h1>\r\n                    <div className=\"flex items-center gap-1 bg-white border border-gray-200 rounded-lg p-1\">\r\n                        <button onClick={() => setViewMode('grid')}\r\n                            className={`p-1.5 rounded ${viewMode === 'grid' ? 'bg-teal-600 text-white' : 'text-gray-500 hover:bg-gray-100'}`}>\r\n                            <LayoutGrid size={15} />\r\n                        </button>\r\n                        <button onClick={() => setViewMode('list')}\r\n                            className={`p-1.5 rounded ${viewMode === 'list' ? 'bg-teal-600 text-white' : 'text-gray-500 hover:bg-gray-100'}`}>\r\n                            <List size={15} />\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n\r\n                {/* Info banner */}\r\n                <div className=\"flex items-start gap-3 mb-6 p-4 bg-blue-50 border border-blue-200 rounded-xl text-sm text-blue-700\">\r\n                    <Users size={18} className=\"shrink-0 mt-0.5 text-blue-500\" />\r\n                    <p>These are folders shared with you by other team members. You can view and access forms inside them.</p>\r\n                </div>\r\n\r\n                {/* Search */}\r\n                {filtered.length > 0 && (\r\n                    <div className=\"relative mb-5 max-w-xs\">\r\n                        <Search size={15} className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" />\r\n                        <input value={search} onChange={e => setSearch(e.target.value)} placeholder=\"Search shared folders...\"\r\n                            className=\"w-full pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm outline-none focus:ring-2 focus:ring-teal-500\" />\r\n                    </div>\r\n                )}\r\n\r\n                {/* Empty state */}\r\n                {sharedToMeFolders.length === 0 ? (\r\n                    <div className=\"bg-white rounded-xl border border-gray-200 shadow-sm flex flex-col items-center justify-center py-24\">\r\n                        <div className=\"relative mb-6\">\r\n                            <svg width=\"88\" height=\"72\" viewBox=\"0 0 88 72\" fill=\"none\">\r\n                                <rect x=\"4\" y=\"20\" width=\"80\" height=\"48\" rx=\"6\" fill=\"#f8fafc\" stroke=\"#e2e8f0\" strokeWidth=\"2\" />\r\n                                <path d=\"M4 28h80\" stroke=\"#e2e8f0\" strokeWidth=\"1.5\" />\r\n                                <rect x=\"4\" y=\"16\" width=\"32\" height=\"12\" rx=\"4\" fill=\"#eff6ff\" stroke=\"#bfdbfe\" strokeWidth=\"1.5\" />\r\n                                {/* People icon in folder */}\r\n                                <circle cx=\"44\" cy=\"50\" r=\"10\" fill=\"#eff6ff\" stroke=\"#bfdbfe\" strokeWidth=\"1.5\" />\r\n                                <circle cx=\"41\" cy=\"48\" r=\"3\" fill=\"#bfdbfe\" />\r\n                                <circle cx=\"47\" cy=\"48\" r=\"3\" fill=\"#bfdbfe\" />\r\n                                <path d=\"M36 54c0-3 5-4 8-4s8 1 8 4\" stroke=\"#bfdbfe\" strokeWidth=\"1.5\" strokeLinecap=\"round\" />\r\n                                <circle cx=\"10\" cy=\"12\" r=\"2\" fill=\"#cbd5e1\" />\r\n                                <circle cx=\"78\" cy=\"10\" r=\"1.5\" fill=\"#cbd5e1\" />\r\n                            </svg>\r\n                        </div>\r\n                        <p className=\"text-gray-500 mb-2\">No folders have been shared with you.</p>\r\n                        <p className=\"text-xs text-gray-300\">When someone shares a folder, it will appear