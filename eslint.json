":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\nimport { useNavigate } from 'react-router-dom';\nimport { X, FileText, LayoutGrid, AlertCircle } from 'lucide-react';\nimport { useFormStore } from '../../store/useFormStore';\nimport { Form } from '../../types';\n\ninterface CreateFormModalProps {\n  onClose: () => void;\n}\n\nexport default function CreateFormModal({ onClose }: CreateFormModalProps) {\n  const [formName, setFormName] = useState('');\n  const [formType, setFormType] = useState<'standard' | 'card'>('standard');\n  const [touched, setTouched] = useState(false);\n  const navigate = useNavigate();\n  const addForm = useFormStore((state) => state.addForm);\n\n  useEffect(() => {\n    const handler = (e: KeyboardEvent) => {\n      if (e.key === 'Escape') onClose();\n      if (e.key === 'Enter' && formName.trim()) handleCreate();\n    };\n    window.addEventListener('keydown', handler);\n    return () => window.removeEventListener('keydown', handler);\n  }, [formName]);\n\n  const handleCreate = () => {\n    setTouched(true);\n    if (!formName.trim()) return;\n    const newForm: Form = {\n      id: `form-${Date.now()}`,\n      name: formName.trim(),\n      type: formType,\n      createdAt: new Date().toISOString().split('T')[0],\n      fields: [],\n      submissions: 0,\n    };\n    addForm(newForm);\n    navigate(`/builder/${newForm.id}`);\n  };\n\n  const isCard = formType === 'card';\n  const previewLabel = formName.trim() || 'Untitled Form';\n\n  return (\n    <div\n      className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n      style={{ backgroundColor: 'rgba(0,0,0,0.5)' }}\n      onClick={onClose}\n    >\n      <div\n        className=\"bg-card rounded-xl shadow-2xl w-full max-w-3xl overflow-hidden animate-in border border-border\"\n        onClick={e => e.stopPropagation()}\n      >\n        {/* Header */}\n        <div className=\"flex items-center justify-between px-7 py-5 border-b border-border\">\n          <div>\n            <h2 className=\"text-xl font-bold text-foreground\">Create New Form</h2>\n            <p className=\"text-sm text-muted-foreground mt-0.5\">Design a form from scratch or choose a template</p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"w-8 h-8 flex items-center justify-center rounded-lg hover:bg-muted text-muted-foreground transition-colors\"\n          >\n            <X size={18} />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-0\">\n          {/* Left: Form */}\n          <div className=\"px-7 py-6 space-y-6\">\n            {/* Form Name */}\n            <div>\n              <label className=\"block text-sm font-semibold text-primary mb-1.5\">\n                Form Name <span className=\"text-destructive\">*</span>\n              </label>\n              <input\n                autoFocus\n                type=\"text\"\n                value={formName}\n                onChange={e => { setFormName(e.target.value); setTouched(false); }}\n                onBlur={() => setTouched(true)}\n                placeholder=\"Enter form name\"\n                className={`w-full px-4 py-3 border rounded-lg outline-none transition-all text-foreground bg-background placeholder:text-muted-foreground\n                  ${touched && !formName.trim()\n                    ? 'border-destructive ring-2 ring-destructive/20'\n                    : 'border-border focus:ring-2 focus:ring-primary/20 focus:border-primary'\n                  }`}\n              />\n              {touched && !formName.trim() && (\n                <div className=\"flex items-center gap-1.5 mt-1.5 text-destructive text-xs\">\n                  <AlertCircle size={12} />\n                  Form name is required.\n                </div>\n              )}\n            </div>\n\n            {/* Form Type */}\n            <div>\n              <label className=\"block text-sm font-semibold text-primary mb-3\">Form Type</label>\n              <div className=\"space-y-3\">\n                {/* Standard */}\n                <button\n                  onClick={() => setFormType('standard')}\n                  className={`w-full p-4 border-2 rounded-xl text-left transition-all ${formType === 'standard'\n                      ? 'border-primary bg-primary/5'\n                      : 'border-border hover:border-primary/40 hover:bg-muted'\n                    }`}\n                >\n                  <div className=\"flex items-start gap-3\">\n                    <div className={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${formType === 'standard' ? 'bg-primary' : 'bg-muted'\n                      }`}>\n                      <FileText size={18} className={formType === 'standard' ? 'text-white' : 'text-muted-foreground'} />\n                    </div>\n                    <div>\n                      <h3 className={`font-semibold mb-0.5 ${formType === 'standard' ? 'text-primary' : 'text-foreground'}`}>\n                        Standard\n                      </h3>\n                      <p className=\"text-sm text-muted-foreground\">Multiple fields per page</p>\n                    </div>\n                    {formType === 'standard' && (\n                      <div className=\"ml-auto w-5 h-5 rounded-full bg-primary flex items-center justify-center shrink-0\">\n                        <svg width=\"10\" height=\"8\" viewBox=\"0 0 10 8\" fill=\"none\">\n                          <path d=\"M1 4l3 3 5-6\" stroke=\"white\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\" />\n                        </svg>\n                      </div>\n                    )}\n                  </div>\n                </button>\n\n                {/* Card */}\n                <button\n                  onClick={() => setFormType('card')}\n                  className={`w-full p-4 border-2 rounded-xl text-left transition-all ${formType === 'card'\n                      ? 'border-primary bg-primary/5'\n                      : 'border-border hover:border-primary/40 hover:bg-muted'\n                    }`}\n                >\n                  <div className=\"flex items-start gap-3\">\n                    <div className={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${formType === 'card' ? 'bg-primary' : 'bg-muted'\n                      }`}>\n                      <LayoutGrid size={18} className={formType === 'card' ? 'text-white' : 'text-muted-foreground'} />\n                    </div>\n                    <div>\n                      <h3 className={`font-semibold mb-0.5 ${formType === 'card' ? 'text-primary' : 'text-foreground'}`}>\n                        Card\n                      </h3>\n                      <p className=\"text-sm text-muted-foreground\">One field per page</p>\n                    </div>\n                    {formType === 'card' && (\n                      <div className=\"ml-auto w-5 h-5 rounded-full bg-primary flex items-center justify-center shrink-0\">\n                        <svg width=\"10\" height=\"8\" viewBox=\"0 0 10 8\" fill=\"none\">\n                          <path d=\"M1 4l3 3 5-6\" stroke=\"white\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\" />\n                        </svg>\n                      </div>\n                    )}\n                  </div>\n                </button>\n              </div>\n            </div>\n          </div>\n\n          {/* Right: Live preview */}\n          <div className=\"hidden md:flex flex-col items-center justify-center bg-muted/40 p-8 border-l border-border\">\n            <div className=\"w-full max-w-[200px]\">\n              <div className=\"bg-card rounded-2xl shadow-lg p-5 border border-border transition-all duration-300\">\n                {/* Icon */}\n                <div className={`w-14 h-14 rounded-xl bg-gradient-to-br ${isCard ? 'from-violet-500 to-purple-600' : 'from-blue-500 to-indigo-600'\n                  } flex items-center justify-center mx-auto mb-4 shadow-md transition-all duration-300`}>\n                  {isCard\n                    ? <LayoutGrid size={28} className=\"text-white\" />\n                    : <FileText size={28} className=\"text-white\" />\n                  }\n                </div>\n\n                <p className={`text-sm font-bold text-center truncate mb-1 transition-all ${formName.trim() ? 'text-foreground' : 'text-muted-foreground'\n                  }`}>\n                  {previewLabel}\n                </p>\n\n                <div className=\"flex items-center justify-center\">\n                  <span className={`text-[11px] font-semibold px-2.5 py-0.5 rounded-full uppercase tracking-widest transition-all border ${isCard\n                      ? 'bg-violet-500/10 text-violet-600 border-violet-500/20'\n                      : 'bg-primary/10 text-primary border-primary/20'\n                    }`}>\n                    {isCard ? 'Card Form' : 'Standard'}\n                  </span>\n                </div>\n\n                <div className=\"mt-4 space-y-2\">\n                  {[60, 80, 50].map((w, i) => (\n                    <div key={i} className=\"h-2 bg-muted rounded-full\" style={{ width: `${w}%` }} />\n                  ))}\n                </div>\n              </div>\n\n              <p className=\"text-xs text-center mt-3 text-muted-foreground\">Live preview</p>\n            </div>\n          </div>\n        </div>\n\n        {/* Footer */}\n        <div className=\"flex items-center justify-between px-7 py-4 border-t border-border bg-muted/30\">\n          <p className=\"text-xs text-muted-foreground\">\n            Press <kbd className=\"px-1.5 py-0.5 bg-card border border-border rounded text-foreground font-mono text-[11px]\">Enter</kbd> to create quickly\n          </p>\n          <div className=\"flex items-center gap-3\">\n            <button\n              onClick={onClose}\n              className=\"px-5 py-2.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground rounded-lg transition-colors font-medium\"\n            >\n              Cancel\n            </button>\n            <button\n              onClick={handleCreate}\n              className={`btn-primary px-6 py-2.5 text-sm rounded-lg font-semibold transition-all shadow-sm\n                ${!formName.trim() ? 'opacity-40 cursor-not-allowed' : 'hover:shadow-md'}`}\n              disabled={!formName.trim()}\n            >\n              Create Form\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\data\\mockData.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\Dashboard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\FeaturePage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\FormBuilder.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":42,"column":56,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":42,"endColumn":59,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1813,1816],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1813,1816],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":50,"column":39,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":50,"endColumn":42,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2052,2055],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2052,2055],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'form' and 'location.state'. Either include them or remove the dependency array.","line":58,"column":6,"nodeType":"ArrayExpression","endLine":58,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [form, id, location.state]","fix":{"range":[2217,2221],"text":"[form, id, location.state]"}}]}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\nimport { useParams, useNavigate, useLocation } from 'react-router-dom';\nimport { ArrowLeft, Eye, Share2, Palette, Settings, Workflow, Zap, ClipboardCheck, GripVertical } from 'lucide-react';\n\nimport {\n  DndContext,\n  DragOverlay,\n  closestCenter,\n  KeyboardSensor,\n  PointerSensor,\n  useSensor,\n  useSensors,\n  DragStartEvent,\n  DragEndEvent,\n} from '@dnd-kit/core';\nimport { arrayMove, sortableKeyboardCoordinates } from '@dnd-kit/sortable';\nimport FieldSidebar from '../components/builder/FieldSidebar';\nimport FormCanvas from '../components/builder/FormCanvas';\nimport FieldSettingsPanel from '../components/builder/FieldSettingsPanel';\nimport FormSettingsPanel from '../components/builder/FormSettingsPanel';\nimport FormThemePanel from '../components/builder/FormThemePanel';\nimport FormSharePanel from '../components/builder/FormSharePanel';\nimport FormRulesPanel from '../components/builder/FormRulesPanel';\nimport FormIntegrationsPanel from '../components/builder/FormIntegrationsPanel';\nimport FormApprovalsPanel from '../components/builder/FormApprovalsPanel';\nimport RichTextModal from '../components/builder/RichTextModal';\n\nimport { FormField, FieldType } from '../types';\nimport { useFormStore } from '../store/useFormStore';\n\n\n\nexport default function FormBuilder() {\n  const { id } = useParams();\n  const navigate = useNavigate();\n  const location = useLocation();\n  const [activeTab, setActiveTab] = useState('builder');\n  const [fields, setFields] = useState<FormField[]>([]);\n  const [selectedFieldId, setSelectedFieldId] = useState<string | null>(null);\n  const [richTextFieldId, setRichTextFieldId] = useState<string | null>(null);\n  const [formName, setFormName] = useState('Untitled Form');\n  const [activeDragItem, setActiveDragItem] = useState<any>(null);\n\n\n  const updateForm = useFormStore((state) => state.updateForm);\n  const form = useFormStore((state) => state.forms.find((f) => f.id === id));\n\n  useEffect(() => {\n    if (id === 'new') {\n      const state = location.state as any;\n      if (state?.name) {\n        setFormName(state.name);\n      }\n    } else if (form) {\n      setFormName(form.name);\n      setFields(form.fields);\n    }\n  }, [id]);\n\n  const updateFieldsState = (newFields: FormField[] | ((prev: FormField[]) => FormField[])) => {\n    setFields((prev) => {\n      const updated = typeof newFields === 'function' ? newFields(prev) : newFields;\n      if (id && id !== 'new') updateForm(id, { fields: updated });\n      return updated;\n    });\n  };\n\n  const handleNameChange = (name: string) => {\n    setFormName(name);\n    if (id && id !== 'new') updateForm(id, { name });\n  };\n\n  const sensors = useSensors(\n    useSensor(PointerSensor),\n    useSensor(KeyboardSensor, {\n      coordinateGetter: sortableKeyboardCoordinates,\n    })\n  );\n\n  const handleDragStart = (event: DragStartEvent) => {\n    setActiveDragItem(event.active.data.current);\n  };\n\n  const handleDragEnd = (event: DragEndEvent) => {\n    const { active, over } = event;\n    setActiveDragItem(null);\n\n    if (!over) return;\n\n    // Moving a field within the canvas\n    if (active.data.current?.type === 'canvas-field' && over.data.current?.type === 'canvas-field') {\n      const oldIndex = fields.findIndex((f) => f.id === active.id);\n      const newIndex = fields.findIndex((f) => f.id === over.id);\n\n      if (oldIndex !== newIndex) {\n        updateFieldsState((items) => {\n          const newItems = arrayMove(items, oldIndex, newIndex);\n          return newItems.map((f, i) => ({ ...f, position: i }));\n        });\n      }\n    }\n\n    // Dropping from sidebar to canvas\n    if (active.data.current?.type === 'sidebar-field' && (over.id === 'form-canvas' || over.data.current?.type === 'canvas-field')) {\n      const draggedFieldType = active.data.current.fieldType;\n\n      // One subform per form rule\n      if (draggedFieldType === 'subform' && fields.some(f => f.type === 'subform')) {\n        return;\n      }\n\n      const newField: FormField = {\n        id: `field-${Date.now()}`,\n        type: draggedFieldType as FieldType,\n        label: `New ${draggedFieldType.charAt(0).toUpperCase() + draggedFieldType.slice(1)}`,\n        required: false,\n        position: fields.length,\n        options: ['dropdown', 'radio', 'checkbox'].includes(draggedFieldType)\n          ? ['Option 1', 'Option 2', 'Option 3']\n          : undefined,\n        subFields: draggedFieldType === 'subform' ? [] : undefined,\n      };\n\n      if (over.id === 'form-canvas') {\n        updateFieldsState([...fields, newField]);\n      } else {\n        const overIndex = fields.findIndex((f) => f.id === over.id);\n        const newFields = [...fields];\n        newFields.splice(overIndex, 0, newField);\n        updateFieldsState(newFields.map((f, i) => ({ ...f, position: i })));\n      }\n      setSelectedFieldId(newField.id);\n      if (draggedFieldType === 'instructions') {\n        setRichTextFieldId(newField.id);\n      }\n    }\n  };\n\n  const handleFieldUpdate = (updates: Partial<FormField>) => {\n    if (selectedFieldId) {\n      updateFieldsState(\n        fields.map((f) => (f.id === selectedFieldId ? { ...f, ...updates } : f))\n      );\n    }\n  };\n\n  const handleFieldUpdateById = (fieldId: string, updates: Partial<FormField>) => {\n    updateFieldsState(fields.map(f => f.id === fieldId ? { ...f, ...updates } : f));\n  };\n\n  const handleFieldDelete = () => {\n    if (selectedFieldId) {\n      updateFieldsState(fields.filter((f) => f.id !== selectedFieldId));\n      setSelectedFieldId(null);\n    }\n  };\n\n  const selectedField = fields.find((f) => f.id === selectedFieldId) || null;\n\n  const tabs = [\n    { id: 'builder', label: 'Builder', icon: <Workflow size={14} /> },\n    { id: 'rules', label: 'Rules', icon: <Zap size={14} /> },\n    { id: 'settings', label: 'Settings', icon: <Settings size={14} /> },\n    { id: 'themes', label: 'Themes', icon: <Palette size={14} /> },\n    { id: 'share', label: 'Share', icon: <Share2 size={14} /> },\n    { id: 'integrations', label: 'Integrations', icon: <Zap size={14} /> },\n    { id: 'approvals', label: 'Approvals', icon: <ClipboardCheck size={14} /> },\n  ];\n\n  return (\n    <div className=\"h-screen flex flex-col\">\n      {/* 螕枚脟螕枚脟 Header (dark navy) 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */}\n      <div className=\"bg-[#0F172A] shrink-0\">\n\n        {/* Row 1: back / name / actions */}\n        <div className=\"px-5 h-12 flex items-center justify-between gap-4\">\n\n          {/* Left: back + name */}\n          <div className=\"flex items-center gap-2 min-w-0\">\n            <button\n              onClick={() => navigate('/')}\n              className=\"p-1.5 hover:bg-white/10 rounded-lg transition-colors flex-shrink-0\"\n            >\n              <ArrowLeft size={16} className=\"text-slate-400\" />\n            </button>\n\n            {/* Separator */}\n            <span className=\"text-slate-700 select-none\">/</span>\n\n            {/* Editable form name */}\n            <input\n              type=\"text\"\n              value={formName}\n              onChange={(e) => handleNameChange(e.target.value)}\n              className=\"text-[14.5px] font-semibold text-white bg-transparent border-none outline-none hover:bg-white/5 focus:bg-white/5 focus:ring-1 focus:ring-white/20 px-2 py-1 rounded-md transition-all min-w-0 w-44 truncate\"\n            />\n\n            {/* Live badge */}\n            <span className=\"flex-shrink-0 flex items-center gap-1 text-[10px] font-semibold text-emerald-400 bg-emerald-400/10 border border-emerald-400/20 px-2 py-0.5 rounded-full\">\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400\" />\n              Live\n            </span>\n\n            {/* Field count */}\n            <span className=\"flex-shrink-0 text-[11px] text-slate-500 font-medium hidden sm:block\">\n              {fields.length} {fields.length === 1 ? 'field' : 'fields'}\n            </span>\n          </div>\n\n          {/* Right: actions */}\n          <div className=\"flex items-center gap-2 flex-shrink-0\">\n            <button\n              onClick={() => navigate(`/submissions/${id}`)}\n              className=\"text-[12.5px] font-medium text-slate-400 hover:text-white hover:bg-white/10 px-3 py-1.5 rounded-lg transition-colors\"\n            >\n              All Entries\n            </button>\n\n            <div className=\"w-px h-4 bg-white/10\" />\n\n            <button\n              onClick={() => navigate(`/form/${id}`)}\n              className=\"flex items-center gap-1.5 px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-[12.5px] font-semibold shadow-sm transition-all\"\n            >\n              <Eye size={13} />\n              Preview\n            </button>\n          </div>\n        </div>\n\n        {/* Row 2: tabs */}\n        <div className=\"px-4 flex items-center gap-0.5 border-t border-white/5\">\n          {tabs.map((tab) => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveTab(tab.id)}\n              className={`\n                relative flex items-center gap-1.5 px-3.5 py-2.5\n                text-[12.5px] font-medium transition-colors\n                ${activeTab === tab.id\n                  ? 'text-white'\n                  : 'text-slate-500 hover:text-slate-300'\n                }\n              `}\n            >\n              {tab.icon}\n              {tab.label}\n              {activeTab === tab.id && (\n                <span className=\"absolute bottom-0 left-0 right-0 h-[2px] bg-blue-500 rounded-t-full\" />\n              )}\n            </button>\n          ))}\n        </div>\n      </div>\n\n\n      {activeTab === 'builder' ? (\n        <DndContext\n          sensors={sensors}\n          collisionDetection={closestCenter}\n          onDragStart={handleDragStart}\n          onDragEnd={handleDragEnd}\n        >\n          <div className=\"flex-1 flex overflow-hidden\">\n            <FieldSidebar />\n\n            <FormCanvas\n              fields={fields}\n              selectedFieldId={selectedFieldId}\n              onFieldSelect={setSelectedFieldId}\n              onFieldUpdate={handleFieldUpdateById}\n            />\n\n            {selectedField && selectedField.type !== 'instructions' && (\n              <FieldSettingsPanel\n                field={selectedField}\n                onUpdate={handleFieldUpdate}\n                onDelete={handleFieldDelete}\n                onClose={() => setSelectedFieldId(null)}\n              />\n            )}\n\n            {/* Rich-text modal for Description/Instructions fields */}\n            {richTextFieldId && (() => {\n              const rtField = fields.find(f => f.id === richTextFieldId);\n              return rtField ? (\n                <RichTextModal\n                  fieldLabel={rtField.label}\n                  content={rtField.helpText ?? ''}\n                  onSave={(content, label) => {\n                    updateFieldsState(fields.map(f =>\n                      f.id === richTextFieldId ? { ...f, label, helpText: content } : f\n                    ));\n                    setRichTextFieldId(null);\n                  }}\n                  onClose={() => setRichTextFieldId(null)}\n                />\n              ) : null;\n            })()}\n          </div>\n\n          <DragOverlay>\n            {activeDragItem ? (\n              activeDragItem.type === 'sidebar-field' ? (\n                <div className=\"p-3 border-2 border-teal-500 bg-white rounded-lg shadow-xl opacity-80 scale-105 pointer-events-none w-32\">\n                  <div className=\"text-xs font-medium text-center text-teal-700\">\n                    {activeDragItem.fieldLabel}\n                  </div>\n                </div>\n              ) : activeDragItem.type === 'canvas-field' ? (\n                <div className=\"p-5 border-2 border-teal-500 bg-white rounded-xl shadow-2xl opacity-90 scale-105 pointer-events-none\">\n                  <div className=\"flex items-start gap-4\">\n                    <div className=\"text-gray-300\">\n                      <GripVertical size={20} />\n                    </div>\n                    <div className=\"flex-1\">\n                      <label className=\"block text-sm font-semibold text-gray-900 mb-1\">\n                        {activeDragItem.field.label}\n                      </label>\n                      <input\n                        type=\"text\"\n                        placeholder=\"Preview\"\n                        className=\"w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50/50\"\n                        disabled\n                      />\n                    </div>\n                  </div>\n                </div>\n              ) : null\n            ) : null}\n          </DragOverlay>\n        </DndContext>\n      ) : activeTab === 'settings' && form ? (\n        <FormSettingsPanel form={form} />\n      ) : activeTab === 'themes' && form ? (\n        <FormThemePanel form={form} />\n      ) : activeTab === 'share' && form ? (\n        <FormSharePanel form={form} />\n      ) : activeTab === 'rules' && form ? (\n        <FormRulesPanel form={form} />\n      ) : activeTab === 'integrations' && form ? (\n        <FormIntegrationsPanel form={form} />\n      ) : activeTab === 'approvals' && form ? (\n        <FormApprovalsPanel form={form} />\n      ) : (\n        <div className=\"flex-1 flex items-center justify-center bg-gray-50\">\n          <div className=\"text-center\">\n            <div className=\"text-gray-400 mb-4\">\n              <Settings size={64} className=\"mx-auto\" />\n            </div>\n            <h3 className=\"text-lg font-medium text-gray-900 mb-2\">\n              {tabs.find((t) => t.id === activeTab)?.label}\n            </h3>\n            <p className=\"text-gray-500\">This section is coming soon</p>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\FormRenderer.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":12,"column":61,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":12,"endColumn":64,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[529,532],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[529,532],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":36,"column":49,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":36,"endColumn":52,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1500,1503],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1500,1503],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":40,"column":35,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":40,"endColumn":38,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1618,1621],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1618,1621],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from 'react';\r\nimport { useParams, useNavigate } from 'react-router-dom';\r\nimport { useFormStore } from '../store/useFormStore';\r\nimport { Star, ArrowLeft } from 'lucide-react';\r\n\r\nexport default function FormRenderer() {\r\n    const { id } = useParams();\r\n    const navigate = useNavigate();\r\n    const form = useFormStore((state) => state.forms.find((f) => f.id === id));\r\n    const addSubmission = useFormStore((state) => state.addSubmission);\r\n\r\n    const [formData, setFormData] = useState<Record<string, any>>({});\r\n    const [submitted, setSubmitted] = useState(false);\r\n\r\n    if (!form) {\r\n        return (\r\n            <div className=\"min-h-screen flex items-center justify-center bg-gray-50\">\r\n                <div className=\"text-center\">\r\n                    <h2 className=\"text-xl font-semibold text-gray-900 mb-2\">Form not found</h2>\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    if (form.settings?.isClosed) {\r\n        return (\r\n            <div className=\"min-h-screen flex items-center justify-center bg-gray-50 p-4\">\r\n                <div className=\"bg-white rounded-xl shadow p-8 max-w-lg w-full text-center\">\r\n                    <h2 className=\"text-2xl font-bold text-gray-900 mb-2\">This form is closed</h2>\r\n                    <p className=\"text-gray-600\">The owner of this form has stopped accepting new responses.</p>\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const handleChange = (label: string, value: any) => {\r\n        setFormData((prev) => ({ ...prev, [label]: value }));\r\n    };\r\n\r\n    const checkCondition = (rule: any) => {\r\n        const fieldName = form.fields.find(f => f.id === rule.fieldId)?.label || '';\r\n        const fieldValue = formData[fieldName];\r\n        if (fieldValue === undefined || fieldValue === '') return false;\r\n\r\n        const val = String(fieldValue).toLowerCase();\r\n        const target = rule.value.toLowerCase();\r\n\r\n        switch (rule.operator) {\r\n            case 'equals': return val === target;\r\n            case 'not_equals': return val !== target;\r\n            case 'contains': return val.includes(target);\r\n            case 'greater_than': return Number(val) > Number(target);\r\n            case 'less_than': return Number(val) < Number(target);\r\n            default: return false;\r\n        }\r\n    };\r\n\r\n    const visibleFields = form.fields.filter(field => {\r\n        const targetingRules = (form.rules || []).filter(r => r.action.targetFieldId === field.id);\r\n        if (targetingRules.length === 0) return true;\r\n\r\n        let isVisible = true;\r\n        for (const rule of targetingRules) {\r\n            const conditionMet = checkCondition(rule.condition);\r\n            if (rule.action.type === 'show') {\r\n                isVisible = conditionMet;\r\n            } else if (rule.action.type === 'hide') {\r\n                if (conditionMet) return false;\r\n            }\r\n        }\r\n        return isVisible;\r\n    });\r\n\r\n    const handleSubmit = (e: React.FormEvent) => {\r\n        e.preventDefault();\r\n        addSubmission({\r\n            id: `sub-${Date.now()}`,\r\n            formId: form.id,\r\n            submittedAt: new Date().toISOString(),\r\n            data: formData,\r\n        });\r\n\r\n        if (form.settings?.redirectUrl) {\r\n            window.location.href = form.settings.redirectUrl;\r\n        } else {\r\n            setSubmitted(true);\r\n        }\r\n    };\r\n\r\n    if (submitted) {\r\n        return (\r\n            <div className=\"min-h-screen bg-gray-50 flex items-center justify-center p-4\">\r\n                <div className=\"max-w-md w-full bg-white rounded-xl shadow-lg p-8 text-center\">\r\n                    <div className=\"w-16 h-16 bg-teal-100 text-teal-600 rounded-full flex items-center justify-center mx-auto mb-4\">\r\n                        <svg className=\"w-8 h-8\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M5 13l4 4L19 7\" />\r\n                        </svg>\r\n                    </div>\r\n                    <h2 className=\"text-2xl font-bold text-gray-900 mb-2\">Thank You!</h2>\r\n                    <p className=\"text-gray-600 mb-6\">\r\n                        {form.settings?.successMessage || 'Your response has been successfully recorded.'}\r\n                    </p>\r\n                    <button\r\n                        onClick={() => navigate('/')}\r\n                        className=\"w-full py-2 bg-teal-600 text-white rounded-lg hover:bg-teal-700 transition-colors\"\r\n                    >\r\n                        Go to Dashboard\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const theme = form.theme || { primaryColor: '#0d9488', backgroundColor: '#f9fafb', fontFamily: 'Inter', textColor: '#111827' };\r\n\r\n    return (\r\n        <div className=\"min-h-screen py-8 px-4\" style={{ backgroundColor: theme.backgroundColor, fontFamily: theme.fontFamily, color: theme.textColor }}>\r\n            <div className=\"max-w-2xl mx-auto\">\r\n                <button\r\n                    onClick={() => navigate(-1)}\r\n                    className=\"flex items-center gap-2 hover:opacity-80 mb-6 transition-opacity\"\r\n                >\r\n                    <ArrowLeft size={20} />\r\n                    Go Back\r\n                </button>\r\n                <div\r\n                    className=\"bg-white rounded-xl shadow-lg p-8\"\r\n                    style={{ borderTop: `6px solid ${theme.primaryColor}` }}\r\n                >\r\n                    <h1 className=\"text-3xl font-bold mb-2\">{form.name}</h1>\r\n                    {form.settings?.description && (\r\n                        <p className=\"opacity-80 mb-6 pb-4 border-b border-gray-100 whitespace-pre-wrap\">\r\n                            {form.settings.description}\r\n                        </p>\r\n                    )}\r\n                    {!form.settings?.description && <div className=\"mb-6 pb-4 border-b border-gray-100\" />}\r\n\r\n                    <form onSubmit={handleSubmit} className=\"space-y-8\">\r\n                        {visibleFields.map((field) => (\r\n                            <div key={field.id} className=\"space-y-2\">\r\n                                <label className=\"block text-sm font-semibold text-gray-900\">\r\n                                    {field.label}\r\n                                    {field.required && <span className=\"text-red-500 ml-1.5\">*</span>}\r\n                                </label>\r\n                                {field.helpText && <p className=\"text-sm text-gray-500\">{field.helpText}</p>}\r\n\r\n                                {(() => {\r\n                                    switch (field.type) {\r\n                                        case 'textbox':\r\n                                        case 'email':\r\n                                        case 'phone':\r\n                                        case 'number':\r\n                                            return (\r\n                                                <input\r\n                                                    type={field.type === 'textbox' ? 'text' : field.type}\r\n                                                    placeholder={field.placeholder || ''}\r\n                                                    required={field.required}\r\n                                                    onChange={(e) => handleChange(field.label, e.target.value)}\r\n                                                    className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none bg-white\"\r\n                                                />\r\n                                            );\r\n                                        case 'dropdown':\r\n                                            return (\r\n                                                <select\r\n                                                    required={field.required}\r\n                                                    onChange={(e) => handleChange(field.label, e.target.value)}\r\n                                                    className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none bg-white\"\r\n                                                >\r\n                                                    <option value=\"\">Select an option...</option>\r\n                                                    {field.options?.map((opt, i) => (\r\n                                                        <option key={i} value={opt}>{opt}</option>\r\n                                                    ))}\r\n                                                </select>\r\n                                            );\r\n                                        case 'radio':\r\n                                            return (\r\n                                                <div className=\"space-y-2\">\r\n                                                    {(field.options || []).map((opt, i) => (\r\n                                                        <label key={i} className=\"flex items-center gap-2\">\r\n                                                            <input\r\n                                                                type=\"radio\"\r\n                                                                name={field.id}\r\n                                                                value={opt}\r\n                                                                required={field.required}\r\n                                                                onChange={(e) => handleChange(field.label, e.target.value)}\r\n                                                                className=\"text-teal-600 focus:ring-teal-500\"\r\n                                                            />\r\n                                                            <span className=\"text-gray-700\">{opt}</span>\r\n                                                        </label>\r\n                                                    ))}\r\n                                                </div>\r\n                                            );\r\n                                        case 'checkbox':\r\n                                            return (\r\n                                                <div className=\"space-y-2\">\r\n                                                    {(field.options || []).map((opt, i) => (\r\n                                                        <label key={i} className=\"flex items-center gap-2\">\r\n                                                            <input\r\n                                                                type=\"checkbox\"\r\n                                                                value={opt}\r\n                                                                onChange={(e) => {\r\n                                                                    const current = formData[field.label] || [];\r\n                                                                    const newArr = e.target.checked\r\n                                                                        ? [...current, opt]\r\n                                                                        : current.filter((x: string) => x !== opt);\r\n                                                                    handleChange(field.label, newArr.length > 0 ? newArr : undefined);\r\n                                                                }}\r\n                                                                className=\"text-teal-600 focus:ring-teal-500 rounded\"\r\n                                                            />\r\n                                                            <span className=\"text-gray-700\">{opt}</span>\r\n                                                        </label>\r\n                                                    ))}\r\n                                                </div>\r\n                                            );\r\n                                        case 'date':\r\n                                            return (\r\n                                                <input\r\n                                                    type=\"date\"\r\n                                                    required={field.required}\r\n                                                    onChange={(e) => handleChange(field.label, e.target.value)}\r\n                                                    className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none bg-white\"\r\n                                                />\r\n                                            );\r\n                                        case 'time':\r\n                                            return (\r\n                                                <input\r\n                                                    type=\"time\"\r\n                                                    required={field.required}\r\n                                                    onChange={(e) => handleChange(field.label, e.target.value)}\r\n                                                    className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none bg-white\"\r\n                                                />\r\n                                            );\r\n                                        case 'rating':\r\n                                            return (\r\n                                                <div className=\"flex gap-2\">\r\n                                                    {[1, 2, 3, 4, 5].map((val) => (\r\n                                                        <button\r\n                                                            key={val}\r\n                                                            type=\"button\"\r\n                                                            onClick={() => handleChange(field.label, val)}\r\n                                                            className=\"focus:outline-none\"\r\n                                                        >\r\n                                                            <Star\r\n                                                                size={32}\r\n                                                                className={\r\n                                                                    (formData[field.label] >= val)\r\n                                                                        ? \"text-yellow-400 fill-yellow-400\"\r\n                                                                        : \"text-gray-300\"\r\n                                                                }\r\n                                                            />\r\n                                                        </button>\r\n                                                    ))}\r\n                                                </div>\r\n                                            );\r\n                                        case 'instructions':\r\n                                            return null;\r\n                                        case 'file':\r\n                                            return (\r\n                                                <input\r\n                                                    type=\"file\"\r\n                                                    required={field.required}\r\n                                                    onChange={(e) => handleChange(field.label, e.target.files?.[0]?.name)}\r\n                                                    className=\"w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-transparent outline-none bg-white\"\r\n                                                />\r\n                                            );\r\n                                        default:\r\n                                            return null;\r\n                                    }\r\n                                })()}\r\n                            </div>\r\n                        ))}\r\n\r\n                        <div className=\"pt-6 border-t border-gray-100\">\r\n                            <button\r\n                                type=\"submit\"\r\n                                style={{ backgroundColor: theme.primaryColor }}\r\n                                className=\"w-full sm:w-auto px-8 py-3 text-white font-medium rounded-lg hover:opacity-90 transition-opacity shadow-sm\"\r\n                            >\r\n                                {form.settings?.submitText || 'Submit Response'}\r\n                            </button>\r\n                        </div>\r\n                    </form>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Hemanth\\Downloads\\project-bolt-sb1-m34ekk4k\\project\\src\\pages\\MyApprovals.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":150,"column":90,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":150,"endColumn":93,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[8106,8109],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[8106,8109],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useMemo } from 'react';\r\nimport MainLayout from '../components/layout/MainLayout';\r\nimport { useFormStore } from '../store/useFormStore';\r\nimport {\r\n    ClipboardCheck, Check, X, Eye, Search,\r\n    Clock, CheckCircle, XCircle, FileText, MessageSquare,\r\n    Calendar, User,\r\n} from 'lucide-react';\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Types 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\ntype ApprovalStatus = 'Pending' | 'Approved' | 'Rejected';\r\n\r\ninterface Approval {\r\n    id: string;\r\n    formId: string;\r\n    formName: string;\r\n    submittedBy: string;\r\n    submittedAt: string;\r\n    status: ApprovalStatus;\r\n    reviewNote?: string;\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Status Badge 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nfunction StatusBadge({ status }: { status: ApprovalStatus }) {\r\n    const cfg: Record<ApprovalStatus, { cls: string; icon: React.ReactNode }> = {\r\n        Pending: {\r\n            cls: 'bg-amber-500/15 text-amber-600 border-amber-500/25',\r\n            icon: <Clock size={11} />\r\n        },\r\n        Approved: {\r\n            cls: 'bg-emerald-500/15 text-emerald-600 border-emerald-500/25',\r\n            icon: <CheckCircle size={11} />\r\n        },\r\n        Rejected: {\r\n            cls: 'bg-destructive/15 text-destructive border-destructive/25',\r\n            icon: <XCircle size={11} />\r\n        },\r\n    };\r\n    const { cls, icon } = cfg[status];\r\n    return (\r\n        <span className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border ${cls}`}>\r\n            {icon} {status}\r\n        </span>\r\n    );\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Action Modal 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nfunction ActionModal({ approval, action, onClose, onConfirm }: {\r\n    approval: Approval;\r\n    action: 'approve' | 'reject';\r\n    onClose: () => void;\r\n    onConfirm: (note: string) => void;\r\n}) {\r\n    const [note, setNote] = useState('');\r\n    const isApprove = action === 'approve';\r\n\r\n    return (\r\n        <div\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center px-4\"\r\n            style={{ backgroundColor: 'rgba(0,0,0,0.5)' }}\r\n            onClick={onClose}\r\n        >\r\n            <div className=\"bg-card rounded-xl shadow-2xl w-full max-w-md border border-border animate-in\" onClick={e => e.stopPropagation()}>\r\n                <div className=\"px-6 py-4 border-b border-border flex items-center justify-between\">\r\n                    <h2 className=\"text-lg font-bold text-foreground\">\r\n                        {isApprove ? 'Approve Submission' : 'Reject Submission'}\r\n                    </h2>\r\n                    <button onClick={onClose} className=\"w-7 h-7 flex items-center justify-center rounded-lg hover:bg-muted text-muted-foreground\">\r\n                        <X size={16} />\r\n                    </button>\r\n                </div>\r\n                <div className=\"px-6 py-5 space-y-4\">\r\n                    <div className=\"p-3 bg-muted/50 rounded-lg space-y-1 border border-border\">\r\n                        <p className=\"text-sm font-semibold text-foreground\">{approval.formName}</p>\r\n                        <p className=\"text-xs text-muted-foreground\">Submitted by <span className=\"font-medium text-foreground\">{approval.submittedBy}</span></p>\r\n                        <p className=\"text-xs text-muted-foreground\">{new Date(approval.submittedAt).toLocaleString()}</p>\r\n                    </div>\r\n                    <div>\r\n                        <label className={`block text-sm font-semibold mb-1 ${isApprove ? 'text-emerald-600' : 'text-destructive'}`}>\r\n                            {isApprove ? 'Approval Note (optional)' : 'Rejection Reason'}\r\n                        </label>\r\n                        <textarea\r\n                            value={note}\r\n                            onChange={e => setNote(e.target.value)}\r\n                            rows={3}\r\n                            placeholder={isApprove ? 'Add a note for the submitter螕脟陋' : 'Provide a reason for rejection螕脟陋'}\r\n                            className=\"w-full px-3 py-2 border border-border rounded-lg text-sm outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary resize-none bg-background text-foreground placeholder:text-muted-foreground\"\r\n                        />\r\n                    </div>\r\n                </div>\r\n                <div className=\"px-6 pb-5 flex justify-end gap-3 border-t border-border pt-4\">\r\n                    <button onClick={onClose} className=\"px-4 py-2 border border-border rounded-lg text-sm text-muted-foreground hover:bg-muted transition-colors font-medium\">Cancel</button>\r\n                    <button\r\n                        onClick={() => { onConfirm(note); onClose(); }}\r\n                        disabled={!isApprove && !note.trim()}\r\n                        className={`px-4 py-2 text-white rounded-lg text-sm font-semibold transition-colors disabled:opacity-50 ${isApprove ? 'bg-emerald-600 hover:bg-emerald-700' : 'bg-destructive hover:bg-destructive/90'\r\n                            }`}\r\n                    >\r\n                        {isApprove ? 'Approve' : 'Reject'}\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Detail Modal 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nfunction DetailModal({ approval, onClose }: { approval: Approval; onClose: () => void }) {\r\n    return (\r\n        <div\r\n            className=\"fixed inset-0 z-50 flex items-center justify-center px-4\"\r\n            style={{ backgroundColor: 'rgba(0,0,0,0.5)' }}\r\n            onClick={onClose}\r\n        >\r\n            <div className=\"bg-card rounded-xl shadow-2xl w-full max-w-md border border-border animate-in\" onClick={e => e.stopPropagation()}>\r\n                <div className=\"px-6 py-4 border-b border-border flex items-center justify-between\">\r\n                    <h2 className=\"text-lg font-bold text-foreground\">Approval Detail</h2>\r\n                    <button onClick={onClose} className=\"w-7 h-7 flex items-center justify-center rounded-lg hover:bg-muted text-muted-foreground\">\r\n                        <X size={16} />\r\n                    </button>\r\n                </div>\r\n                <div className=\"px-6 py-5 space-y-3\">\r\n                    {[\r\n                        { icon: <FileText size={15} />, label: 'Form', value: approval.formName },\r\n                        { icon: <User size={15} />, label: 'Submitted By', value: approval.submittedBy },\r\n                        { icon: <Calendar size={15} />, label: 'Submitted At', value: new Date(approval.submittedAt).toLocaleString() },\r\n                        { icon: <ClipboardCheck size={15} />, label: 'Status', value: <StatusBadge status={approval.status} /> },\r\n                        ...(approval.reviewNote ? [{ icon: <MessageSquare size={15} />, label: 'Review Note', value: approval.reviewNote }] : []),\r\n                    ].map(({ icon, label, value }) => (\r\n                        <div key={label} className=\"flex items-start gap-3 py-2 border-b border-border/50 last:border-0\">\r\n                            <span className=\"text-muted-foreground mt-0.5 shrink-0\">{icon}</span>\r\n                            <div className=\"flex-1\">\r\n                                <p className=\"text-xs text-muted-foreground mb-0.5\">{label}</p>\r\n                                <div className=\"text-sm font-medium text-foreground\">{value}</div>\r\n                            </div>\r\n                        </div>\r\n                    ))}\r\n                </div>\r\n                <div className=\"px-6 pb-5 pt-4 flex justify-end border-t border-border\">\r\n                    <button onClick={onClose} className=\"px-4 py-2 border border-border rounded-lg text-sm text-muted-foreground hover:bg-muted transition-colors font-medium\">Close</button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Seed demo approvals 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nfunction buildInitialApprovals(\r\n    forms: { id: string; name: string }[],\r\n    submissions: { id: string; formId: string; submittedAt: string; data: Record<string, any> }[]\r\n): Approval[] {\r\n    return submissions.slice(0, 6).map((sub, i) => {\r\n        const form = forms.find(f => f.id === sub.formId);\r\n        const statuses: ApprovalStatus[] = ['Pending', 'Pending', 'Approved', 'Pending', 'Rejected', 'Approved'];\r\n        return {\r\n            id: `approval-${sub.id}`,\r\n            formId: sub.formId,\r\n            formName: form?.name || 'Unknown Form',\r\n            submittedBy: (sub.data['Full Name'] || sub.data['Email Address'] || `User ${i + 1}`) as string,\r\n            submittedAt: sub.submittedAt,\r\n            status: statuses[i] ?? 'Pending',\r\n            reviewNote: statuses[i] === 'Rejected' ? 'Missing required documentation.' : statuses[i] === 'Approved' ? 'All checks passed.' : undefined,\r\n        };\r\n    });\r\n}\r\n\r\ntype StatusFilter = ApprovalStatus | 'All';\r\n\r\n/* 螕枚脟螕枚脟螕枚脟 Main Page 螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟螕枚脟 */\r\nexport default function MyApprovals() {\r\n    const allForms = useFormStore(state => state.forms);\r\n    const allSubmissions = useFormStore(state => state.submissions);\r\n\r\n    const [approvals, setApprovals] = useState<Approval[]>(() =>\r\n        buildInitialApprovals(allForms, allSubmissions)\r\n    );\r\n    const [statusFilter, setStatusFilter] = useState<StatusFilter>('All');\r\n    const [search, setSearch] = useState('');\r\n    const [actionModal, setActionModal] = useState<{ approval: Approval; action: 'approve' | 'reject' } | null>(null);\r\n    const [detailModal, setDetailModal] = useState<Approval | null>(null);\r\n\r\n    const counts = useMemo(() => ({\r\n        All: approvals.length,\r\n        Pending: approvals.filter(a => a.status === 'Pending').length,\r\n        Approved: approvals.filter(a => a.status === 'Approved').length,\r\n        Rejected: approvals.filter(a => a.status === 'Rejected').length,\r\n    }), [approvals]);\r\n\r\n    const filtered = useMemo(() =>\r\n        approvals.filter(a => {\r\n            const matchStatus = statusFilter === 'All' || a.status === statusFilter;\r\n            const matchSearch = !search || a.formName.toLowerCase().includes(search.toLowerCase()) || a.submittedBy.toLowerCase().includes(search.toLowerCase());\r\n            return matchStatus && matchSearch;\r\n        }),\r\n        [approvals, statusFilter, search]\r\n    );\r\n\r\n    const handleAction = (id: string, newStatus: ApprovalStatus, note: string) => {\r\n        setApprovals(prev => prev.map(a => a.id === id ? { ...a, status: newStatus, reviewNote: note || undefined } : a));\r\n    };\r\n\r\n    const TABS: StatusFilter[] = ['All', 'Pending', 'Approved', 'Rejected'];\r\n\r\n    return (\r\n        <MainLayout onNewFormClick={() => { }}>\r\n            <div className=\"max-w-6xl mx-auto animate-in\">\r\n                {/* Header */}\r\n                <div className=\"mb-7\">\r\n                    <h1 className=\"text-4xl font-bold text-foreground tracking-tight\">My Approvals</h1>\r\n                    <p className=\"text-sm text-muted-foreground mt-1\">Review and act on form submissions pending your approval</p>\r\n                </div>\r\n\r\n                {/* Stat cards */}\r\n                <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 mb-7\">\r\n                    {TABS.map(tab => (\r\n                        <button\r\n                            key={tab}\r\n                            onClick={() => setStatusFilter(tab)}\r\n                            className={`text-left p-5 rounded-xl border transition-all shadow-sm bg-card ${statusFilter === tab\r\n                                    ? 'border-primary ring-1 ring-primary/20'\r\n                                    : 'border-border hover:border-primary/30'\r\n                                }`}\r\n                        >\r\n                            <p className={`text-xs font-black uppercase tracking-widest mb-2 ${statusFilter === tab ? 'text-primary' : 'text-muted-foreground'\r\n                                }`}>{tab}</p>\r\n                            <p className={`text-3xl font-bold ${statusFilter === tab ? 'text-primary' : 'text-foreground'}`}>\r\n                                {counts[tab]}\r\n                            </p>\r\n                        </button>\r\n                    ))}\r\n                </div>\r\n\r\n                {/* Table card */}\r\n                <div className=\"bg-card rounded-xl border border-border shadow-sm overflow-hidden\">\r\n                    {/* Toolbar